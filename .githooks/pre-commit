#!/bin/sh
# Wrapper para ejecutar el hook en Python tanto en Windows como Unix
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Buscar Python disponible
if [ -f "$ROOT/backend/venv/Scripts/python.exe" ]; then
    "$ROOT/backend/venv/Scripts/python.exe" "$SCRIPT_DIR/pre-commit.py"
elif [ -f "$ROOT/backend/venv/bin/python" ]; then
    "$ROOT/backend/venv/bin/python" "$SCRIPT_DIR/pre-commit.py"
else
    python "$SCRIPT_DIR/pre-commit.py" 2>/dev/null || python3 "$SCRIPT_DIR/pre-commit.py"
fi
